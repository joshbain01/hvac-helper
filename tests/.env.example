# ─────────────────────────────────────────────────────────────────────────────
# HVAC Helper — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# DO NOT commit a filled-in copy of this file. .env is gitignored.
#
# Bootstrap:
#   1. Copy this file to .env at the repo root:  cp tests/.env.example .env
#   2. Fill in every value marked replace-with-*
#   3. Push to each Pi:  ./tests/scripts/bootstrap-secrets.sh <pi-host>
#
# Rotating a secret:
#   Edit .env locally, then re-run bootstrap-secrets.sh for each affected host.
# ─────────────────────────────────────────────────────────────────────────────

# Bearer token used by the HVAC API to authenticate inbound requests.
# Generate with:  openssl rand -hex 32
API_BEARER_TOKEN=replace-with-secure-random-token

# OpenRouter API key for LLM-powered note expansion and AI analysis.
# Obtain at: https://openrouter.ai/keys
OPENROUTER_API_KEY=replace-with-openrouter-key

# LLM model routing target (no secret — safe to change freely).
KIMI_MODEL=moonshotai/kimi-k2.5

# Absolute path to the SQLite database inside the Docker volume.
DB_PATH=/data/test_telemetry.db
